<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>fxOrderNumber__c</fullName>
    <businessStatus>Active</businessStatus>
    <description>this field is in use for SAP_Order_Summary__c (PKI Order Summary) and converts the text based order number to a numeric value for comparison in L.FLOW 5010</description>
    <externalId>false</externalId>
    <formula>VALUE( SAP_Order__c )</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>fxOrderNumber</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
