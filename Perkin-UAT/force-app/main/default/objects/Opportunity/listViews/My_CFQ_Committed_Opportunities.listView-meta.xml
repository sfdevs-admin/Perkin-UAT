<?xml version="1.0" encoding="UTF-8"?>
<ListView xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>My_CFQ_Committed_Opportunities</fullName>
    <columns>CORE.USERS.FULL_NAME</columns>
    <columns>OPPORTUNITY.NAME</columns>
    <columns>TERR2_NAME</columns>
    <columns>OPPORTUNITY.TYPE</columns>
    <columns>OPPORTUNITY.STAGE_NAME</columns>
    <columns>OPPORTUNITY.NEXT_STEP</columns>
    <columns>Global_Region__c</columns>
    <columns>OPPORTUNITY.CREATED_DATE</columns>
    <columns>OPPORTUNITY.CLOSE_DATE</columns>
    <columns>OPPORTUNITY.FORECAST_CATEGORY</columns>
    <columns>Current_Quote_Number__c</columns>
    <columns>SAP_Quote__c</columns>
    <columns>OPPORTUNITY.AMOUNT</columns>
    <filterScope>Everything</filterScope>
    <filters>
        <field>OPPORTUNITY.CREATED_DATE</field>
        <operation>equals</operation>
        <value>THIS_MONTH</value>
    </filters>
    <filters>
        <field>OPPORTUNITY.FORECAST_CATEGORY</field>
        <operation>equals</operation>
        <value>Pipeline,Best Case,Commit</value>
    </filters>
    <filters>
        <field>OPPORTUNITY.RECORDTYPE</field>
        <operation>equals</operation>
        <value>Opportunity.PKI_Americas_SPI</value>
    </filters>
    <filters>
        <field>Global_Region__c</field>
        <operation>equals</operation>
        <value>Americas,apac,Emea</value>
    </filters>
    <filters>
        <field>OPPORTUNITY.TYPE</field>
        <operation>equals</operation>
        <value>Demo – New Unit Request ($0-SIOP Planning only),Demo – For Sale to Customer ($$-Not for SIOP planning),Instrument,Instrument Upgrade,Large Instrument</value>
    </filters>
    <filters>
        <field>OPPORTUNITY.AMOUNT</field>
        <operation>notEqual</operation>
        <value>USD 0</value>
    </filters>
    <label>AME CFQ All Opportunities (Excl Abandon)</label>
    <sharedTo>
        <allInternalUsers />
    </sharedTo>
</ListView>
