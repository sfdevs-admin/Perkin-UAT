<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>INF_Populate_Research_Analytics</fullName>
    <active>true</active>
    <description>2022.02.10 Updated per: INC0289573.
used for INF....user must fill in INF_Analytics_AVS__c if blank on select records</description>
    <errorConditionFormula>AND(
    NOT($Permission.C_PERM_8020_Bypass_Opp_V_RULE)  
   ,ISBLANK(INF_Analytics_AVS__c)
   ,ISCHANGED(StageName)
   ,fxStageNumber__c &lt;=7
   ,RecordType.Name = &quot;Informatics&quot;
   ,OR(
     INCLUDES(Product_Line_Name__c,&#39;AVC&#39;)
    ,INCLUDES(Product_Line_Name__c,&#39;AVS&#39;)
     )
  )</errorConditionFormula>
    <errorDisplayField>INF_Analytics_AVS__c</errorDisplayField>
    <errorMessage>V.RULE_OPP_069: Please provide Research Analytics</errorMessage>
</ValidationRule>
