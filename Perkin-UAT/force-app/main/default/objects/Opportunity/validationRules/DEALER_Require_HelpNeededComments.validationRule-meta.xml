<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>DEALER_Require_HelpNeededComments</fullName>
    <active>true</active>
    <description>Help Needed Comments Is Mandatory if Help needed is &#39;Yes&#39;</description>
    <errorConditionFormula>AND(
CONTAINS(fxRecordTypeName__c,&#39;Dealer&#39;)
/*,CONTAINS($User.License_type__c,&#39;Partner&#39;)*/
, CONTAINS($Profile.Name,&#39;Dealer&#39;)
, TEXT(Help_Needed__c)=&#39;Yes&#39;
, ISBLANK(Help_Need_Comments__c)
)</errorConditionFormula>
    <errorDisplayField>Help_Need_Comments__c</errorDisplayField>
    <errorMessage>V.RULE_OPP_049: Please enter help needed comments</errorMessage>
</ValidationRule>
