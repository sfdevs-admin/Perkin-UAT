<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>INF_Order_Number_Mandatory</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT( $Permission.C_PERM_8030_Bypass_OwnedByCompany_V_RULE )
    ,ISBLANK(GP_OrderNum_INF__c)
    ,TEXT(StageName) = &#39;Closed Won&#39;
    ,fxRecordTypeDevName__c =&#39;Informatics&#39;
    )</errorConditionFormula>
    <errorDisplayField>GP_OrderNum_INF__c</errorDisplayField>
    <errorMessage>V.RULE_OPP_028: Please enter the Order Number before closing an Opportunity</errorMessage>
</ValidationRule>
