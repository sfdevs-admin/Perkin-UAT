<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>BD_Is_Special__c</fullName>
    <description>Used in CPQ Custom Action to exclude special products from the quote line editor</description>
    <formula>BEGINS ( Partnum__c , &quot;SPECIAL&quot;)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Is Special</label>
    <trackHistory>false</trackHistory>
    <type>Checkbox</type>
</CustomField>
