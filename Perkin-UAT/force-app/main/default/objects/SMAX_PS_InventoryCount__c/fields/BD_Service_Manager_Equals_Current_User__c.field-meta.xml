<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>BD_Service_Manager_Equals_Current_User__c</fullName>
    <description>Check if the Service Manager field matches the Current User that is logged in.</description>
    <formula>IF(BD_Service_Manager__c = $User.Id, true, false)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Service Manager Equals Current User</label>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Checkbox</type>
</CustomField>
