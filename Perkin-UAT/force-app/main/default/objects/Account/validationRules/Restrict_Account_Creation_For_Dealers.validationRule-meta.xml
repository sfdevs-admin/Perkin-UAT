<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Restrict_Account_Creation_For_Dealers</fullName>
    <active>true</active>
    <description>Dealers cant create new accounts</description>
    <errorConditionFormula>AND(
     ISNEW()
    ,$Profile.Name = &#39;Dealer&#39;
   )</errorConditionFormula>
    <errorMessage>V.RULE_ACCOUNT_007: Dealers cant create new Account. Please contact admin</errorMessage>
</ValidationRule>
