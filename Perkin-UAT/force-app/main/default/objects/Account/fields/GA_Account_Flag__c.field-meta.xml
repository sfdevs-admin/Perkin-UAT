<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>GA_Account_Flag__c</fullName>
    <description>PKI - Displays a graphic indicating that the account record is a global account</description>
    <externalId>false</externalId>
    <formula>IF(NOT(ISBLANK( GA_Global_Account_Program__c)),IMAGE(&quot;/resource/GA_Account_Flag&quot;, &quot;GA Account&quot;), &quot;&quot;)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Global Account Flag</inlineHelpText>
    <label>Account Flag</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
