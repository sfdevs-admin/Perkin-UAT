<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>fxCreatedWeekday__c</fullName>
    <description>This will provide the Calendar Day of Week the Interaction was created</description>
    <externalId>false</externalId>
    <formula>CASE(WEEKDAY(DATEVALUE(CreatedDate ))
,1,&#39;Sunday&#39;
,2,&#39;Monday&#39;
,3,&#39;Tuesday&#39;
,4,&#39;Wednesday&#39;
,5,&#39;Thursday&#39;
,6,&#39;Friday&#39;
,&#39;Saturday&#39;)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>This will provide the Calendar Day of Week the Interaction was created</inlineHelpText>
    <label>fxCreatedWeekday</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
