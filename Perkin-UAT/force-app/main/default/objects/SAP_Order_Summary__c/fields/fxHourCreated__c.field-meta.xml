<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>fxHourCreated__c</fullName>
    <description>This is the Hour that the record was created (for metrics)</description>
    <externalId>false</externalId>
    <formula>/*RIGHT(&quot;0&quot; &amp; TEXT(HOUR(TIMEVALUE(CreatedDate))-5),2)*/

RIGHT(&quot;0&quot; &amp; MID( TEXT(CreatedDate + ($User.UserTimezoneOffset__c/24)), 12, 2 ),2 )</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>fxHourCreated</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
