<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Base_Target_Achieved__c</fullName>
    <formula>IF(  Total_Opportunity_Amount__c  = 0, 0, Won_Revenue__c / Base_Target__c )</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Total Amount of Closed Won opportunities compared to Base Target for this rep this month</inlineHelpText>
    <label>Base Target Achieved</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
