<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Forecast_Stretch_Target_Achievement__c</fullName>
    <formula>IF (Total_Opportunity_Amount__c = 0, 0, (  Total_Forecast_Revenue__c  / Stretch_Target__c ))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Total Amount of Closed Won and Commit opportunities compared to Stretch Target for this rep this month</inlineHelpText>
    <label>Forecast Stretch Target Achievement</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Percent</type>
</CustomField>
