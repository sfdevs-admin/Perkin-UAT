<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Fiscal_Qtr__c</fullName>
    <description>the Fiscal Quarter for the Date field as text, used to group on in reporting, and for filtering</description>
    <externalId>false</externalId>
    <formula>TEXT(YEAR( Date__c )) + &#39;-&#39; +  CASE( MONTH( Date__c ) , 1, &#39;Q1&#39;,
                                                         2, &#39;Q1&#39;, 
                                                         3, &#39;Q1&#39;,
                                                         4, &#39;Q2&#39;,
                                                         5, &#39;Q2&#39;,
                                                         6, &#39;Q2&#39;,
                                                         7, &#39;Q3&#39;,
                                                         8, &#39;Q3&#39;,
                                                         9, &#39;Q3&#39;,
                                                         10, &#39;Q4&#39;,
                                                         11, &#39;Q4&#39;,
                                                         12, &#39;Q4&#39;, NULL)</formula>
    <label>Fiscal Qtr</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
