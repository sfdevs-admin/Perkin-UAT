<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>fxMonthsInFuture__c</fullName>
    <description>formula to calculat ehow many months in the future this data point is so we can easily find gaps or add missing months</description>
    <externalId>false</externalId>
    <formula>IF( MONTH(Date__c) &lt; MONTH(TODAY()), 0 , MONTH(Date__c) - MONTH(TODAY()) )</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>fxMonthsInFuture</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
