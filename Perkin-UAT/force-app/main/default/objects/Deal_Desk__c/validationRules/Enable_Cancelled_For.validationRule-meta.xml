<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Enable_Cancelled_For</fullName>
    <active>true</active>
    <errorConditionFormula>AND($Permission.BD_Bypass_Automation != TRUE, ISCHANGED(Request_Cancelled__c), Request_Cancelled__c = TRUE ,ISBLANK(Cancelled_For__c))</errorConditionFormula>
    <errorDisplayField>Cancelled_For__c</errorDisplayField>
    <errorMessage>Please provide a note on cancellation of the request</errorMessage>
</ValidationRule>
