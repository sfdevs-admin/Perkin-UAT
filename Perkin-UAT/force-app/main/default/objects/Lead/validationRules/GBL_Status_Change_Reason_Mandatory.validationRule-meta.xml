<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>GBL_Status_Change_Reason_Mandatory</fullName>
    <active>false</active>
    <errorConditionFormula>AND(ISPICKVAL( Status , &quot;Abandoned&quot;),
    ISPICKVAL( Status_Change_Reason__c,&quot;&quot;),
				$Setup.Rules_Execution__c.Run__c)</errorConditionFormula>
    <errorMessage>V.RULE_LEAD_007: Please enter  &quot;Status Change Reason&quot; for setting a lead as &quot;Abandoned&quot;</errorMessage>
</ValidationRule>
