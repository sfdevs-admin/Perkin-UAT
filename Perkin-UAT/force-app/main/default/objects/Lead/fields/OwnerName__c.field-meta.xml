<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>OwnerName__c</fullName>
    <description>Field to fetch the Owner name, it could be both User or Queue</description>
    <externalId>false</externalId>
    <formula>IF(ISBLANK( Owner:Queue.Id ),Owner:User.FirstName &amp;  Owner:User.LastName,Owner:Queue.QueueName  )</formula>
    <label>OwnerName</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
