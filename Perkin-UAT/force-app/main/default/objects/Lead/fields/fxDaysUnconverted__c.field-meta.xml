<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>fxDaysUnconverted__c</fullName>
    <description>Determines the number of days lead is unconverted since it was created. -1 indicates lead has been converted.</description>
    <externalId>false</externalId>
    <formula>IF(IsConverted = false
  , TODAY() - DATEVALUE(CreatedDate) 
  , -1
)</formula>
    <label>fxDaysUnconverted</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
