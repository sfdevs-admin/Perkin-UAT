<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Entitlement_Status__c</fullName>
    <externalId>false</externalId>
    <formula>IF( Entitlement_End__c   &lt;=    DATEVALUE( CreatedDate ) , &quot;No Coverage&quot;, &quot;Active&quot;)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Status is calculated to be Active if the Case was created before the Entitlement End Date.</inlineHelpText>
    <label>Entitlement Status</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
