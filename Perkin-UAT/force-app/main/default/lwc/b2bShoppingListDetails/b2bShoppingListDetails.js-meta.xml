<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>B2B Custom Shopping List Details</masterLabel>
    <targets>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target> 
    </targets>
    <targetConfigs>
        <targetConfig targets="lightningCommunity__Default">
            <property name="isPublicListPage" type="Boolean" default="false" />
            <property name="initialVisibleCount" type="Integer" label="Initial Visible Items" description="How many items to show initially" default="20" />
            <property name="pageSize" type="Integer" label="Page Size" description="How many items to load on each 'Show More'" default="20" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
