    public static Map<String,Object> getData(Map<String,Object> mapParams){
        Boolean isSuccess = false;
        String message = '';
        List<B2B_Homepage_Carousel__mdt> imageDataList = [SELECT Id, B2B_Image_URL__c, B2B_Link_URL__c, B2B_URL_Target__c FROM B2B_Homepage_Carousel__mdt];
        if( ! imageDataList.isEmpty() ){
            mapParams.put('imageDataList', imageDataList);
            isSuccess = true;
        }else{
            message = 'No images found';
        }
        mapParams.put('isSuccess', isSuccess);
        mapParams.put('message', message);
        return mapParams;
    }
