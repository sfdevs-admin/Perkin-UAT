public class MergePDFController {

    /**
     * @description SC-459 Method to get list of Base64 encoded Quote document files.
     * These are documents generated by CPQ SBQQ.ServiceRouter stored in Document records.
     * @param documentIds : List if Salesforce Document.Id
     * return : Map of files data
     */
    @AuraEnabled(Cacheable=true)
    public static List<Map<String, String>> getPdfFilesAsBase64(List<String> documentIds) {

        // Document files has to be properly named
        // so the merged document will be then have right sections order
        List<Document> documents = [
			SELECT Id, FolderId, Name, Type, Body, BodyLength
            FROM Document
            WHERE Id IN :documentIds
            ORDER BY Name
        ];
            
        List<Map<String, String>> pdfFiles = new List<Map<String, String>>();
        for (Document doc : documents) {
            Map<String, String> pdfData = new Map<String, String>();
            pdfData.put('DocumentId', doc.Id);
            pdfData.put('Base64Data', EncodingUtil.base64Encode(doc.Body));
            pdfFiles.add(pdfData);
        }
        
        return pdfFiles;
    }

    /**
     * @description SC-459 Method to save combined PDF file. Content is Base64 encoded.
     * @param documentName : Name of the target Document record
     * @param base64Data : Base64 encoded file content
     * return : Salesforce Document.Id for new record created
     */
    @AuraEnabled
    public static String savePdfFileAsBase64(String documentName, String base64Data) {

        Document doc = new Document(
            Name = documentName,
            FolderId = UserInfo.getUserId(),
            Body = EncodingUtil.base64Decode(base64Data)
        );
        insert doc;

        return doc.Id;
    }

}